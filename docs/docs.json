{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "kensa",
  "description": "Kensa turns agent traces into pytest evals that run in CI.",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "icons": {
    "library": "lucide"
  },
  "metadata": {
    "timestamp": true
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "colors": {
    "primary": "#090909",
    "light": "#f3f3f3",
    "dark": "#949494"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": [
          "introduction",
          "quickstart",
          "concepts"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "cases",
          "assertions",
          "judge",
          "tracing",
          "pytest"
        ]
      },
      {
        "group": "Workflows",
        "pages": [
          "skills",
          "cli",
          "ci"
        ]
      },
      {
        "group": "Releases",
        "pages": [
          "changelog"
        ]
      }
    ]
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/kensa-sh/kensa"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/kensa-sh/kensa",
      "x": "https://x.com/kensa_sh"
    }
  },
  "seo": {
    "metatags": {
      "og:site_name": "Kensa docs",
      "twitter:site": "@kensa_sh"
    },
    "indexing": "all"
  }
}
